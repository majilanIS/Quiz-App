{
  "expo": {
    "name": "Quiz-App",
    "slug": "Quiz-App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_icon-1.png",
    "scheme": "quizapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/images/forbackground-quiz-app.png",
        "backgroundImage": "./assets/images/images/background-quiz-app.png",
        "monochromeImage": "./assets/images/quiz-app-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.chekole.QuizApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/images/logo_icon-1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/forbackground-quiz-app.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "474425b0-92e9-4ea9-b22b-86e6f3ead34c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/474425b0-92e9-4ea9-b22b-86e6f3ead34c"
    }
  }
}
